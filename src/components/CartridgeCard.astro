---
interface Stat {
  label: string;
  value: string;
}

interface Props {
  rank?: string;      // e.g. "No. 1"
  rankLabel?: string;  // e.g. "Best All-Around"
  name: string;        // e.g. ".350 Legend"
  url?: string;        // optional link — wraps the name in a link when set
  linkRel?: string;    // rel attribute for the link. Defaults to "sponsored noopener" for
                        // affiliate use; pass "noopener" for non-affiliate citations (e.g. DNR sources)
  description: string;
  stats: Stat[];
}

const { rank, rankLabel, name, url, linkRel = 'sponsored noopener', description, stats } = Astro.props as Props;
---

<div class="cfb-cartridge-card">
  {(rank || rankLabel) && (
    <p class="cfb-cartridge-card__eyebrow">
      {rank}{rank && rankLabel ? ' — ' : ''}{rankLabel}
    </p>
  )}
  <h3 class="cfb-cartridge-card__name">
    {url ? (
      <a href={url} class="cfb-cartridge-card__link" rel={linkRel} target="_blank">{name}</a>
    ) : (
      name
    )}
  </h3>
  <p class="cfb-cartridge-card__desc">{description}</p>
  <div class="cfb-cartridge-card__stats">
    {stats.map((stat) => (
      <div class="cfb-cartridge-card__stat">
        <span class="cfb-cartridge-card__stat-label">{stat.label}</span>
        <span class="cfb-cartridge-card__stat-value">{stat.value}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .cfb-cartridge-card {
    background: var(--frost);
    border-left: 4px solid var(--blaze);
    padding: 1.25rem 1.5rem;
    margin: 0 0 1.25rem;
  }

  .cfb-cartridge-card__eyebrow {
    font-family: var(--font-tag);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--blaze);
    margin: 0 0 0.4rem;
  }

  .cfb-cartridge-card__name {
    font-family: var(--font-display);
    font-size: 1.35rem;
    margin: 0 0 0.5rem;
    color: var(--ink);
  }

  .cfb-cartridge-card__link {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--blaze);
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
  }

  .cfb-cartridge-card__link:hover {
    color: var(--blaze);
  }

  .cfb-cartridge-card__desc {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--ink);
    margin: 0 0 1rem;
  }

  .cfb-cartridge-card__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.5rem;
    border-top: 1px solid var(--stalk);
    padding-top: 0.75rem;
  }

  .cfb-cartridge-card__stat {
    display: flex;
    flex-direction: column;
    font-family: var(--font-tag);
    font-size: 0.7rem;
  }

  .cfb-cartridge-card__stat-label {
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--stalk);
    margin-bottom: 0.15rem;
  }

  .cfb-cartridge-card__stat-value {
    color: var(--ink);
    font-weight: 700;
  }

  @media (max-width: 480px) {
    .cfb-cartridge-card__stats {
      gap: 0.5rem 1rem;
    }
  }
</style>
