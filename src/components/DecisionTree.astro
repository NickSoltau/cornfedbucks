---
// Static five-lane decision-tree diagram: recoil tier -> platform -> distance -> cartridge.
// Visual language matches ZoneMapEmbed.astro (dark card, orange top accent, mono/Oswald type).
---

<div class="decision-tree">
  <div class="wrap">
    <p class="eyebrow">CornfedBucks &middot; Decision Framework</p>
    <h2>Find Your Straight-Wall Cartridge</h2>
    <p class="sub">Follow the path that matches your recoil tolerance, then your rifle platform, then your typical shot distance, to land on a cartridge.</p>

    <div class="tree-card">
      <svg viewBox="0 0 1000 640" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Decision tree for choosing a straight-wall cartridge based on recoil tolerance, rifle platform, and shot distance">

        <!-- Column headers -->
        <text x="130" y="30" class="col-label">RECOIL TIER</text>
        <text x="400" y="30" class="col-label">PLATFORM</text>
        <text x="650" y="30" class="col-label">TYPICAL DISTANCE</text>
        <text x="880" y="30" class="col-label">CARTRIDGE</text>

        <!-- Recoil tier nodes -->
        <rect x="40" y="70" width="180" height="60" rx="4" class="node node-recoil"/>
        <text x="130" y="95" class="node-title">Low Tolerance</text>
        <text x="130" y="113" class="node-sub">youth / new hunters</text>

        <rect x="40" y="270" width="180" height="60" rx="4" class="node node-recoil"/>
        <text x="130" y="295" class="node-title">Moderate Tolerance</text>
        <text x="130" y="313" class="node-sub">used to a .243 or .30-30</text>

        <rect x="40" y="480" width="180" height="60" rx="4" class="node node-recoil"/>
        <text x="130" y="505" class="node-title">High Tolerance</text>
        <text x="130" y="523" class="node-sub">wants max stopping power</text>

        <!-- Platform nodes -->
        <rect x="310" y="70" width="180" height="60" rx="4" class="node node-platform"/>
        <text x="400" y="95" class="node-title">Bolt-Action / AR-15</text>
        <text x="400" y="113" class="node-sub">.350 Legend</text>

        <rect x="310" y="200" width="180" height="60" rx="4" class="node node-platform"/>
        <text x="400" y="225" class="node-title">Bolt-Action / AR-15</text>
        <text x="400" y="243" class="node-sub">.400 Legend or .360 Buckhammer</text>

        <rect x="310" y="340" width="180" height="60" rx="4" class="node node-platform"/>
        <text x="400" y="365" class="node-title">Lever-Action</text>
        <text x="400" y="383" class="node-sub">.360 Buckhammer or .45-70</text>

        <rect x="310" y="480" width="180" height="60" rx="4" class="node node-platform"/>
        <text x="400" y="505" class="node-title">Bolt-Action / AR-15</text>
        <text x="400" y="523" class="node-sub">.450 Bushmaster</text>

        <rect x="310" y="560" width="180" height="60" rx="4" class="node node-platform"/>
        <text x="400" y="585" class="node-title">Lever-Action</text>
        <text x="400" y="603" class="node-sub">.45-70 Government</text>

        <!-- Distance nodes -->
        <rect x="560" y="70" width="180" height="60" rx="4" class="node node-distance"/>
        <text x="650" y="95" class="node-title">Inside 150 Yards</text>
        <text x="650" y="113" class="node-sub">standard field shots</text>

        <rect x="560" y="270" width="180" height="60" rx="4" class="node node-distance"/>
        <text x="650" y="295" class="node-title">Up to 175&ndash;200 Yards</text>
        <text x="650" y="313" class="node-sub">open field edges</text>

        <rect x="560" y="480" width="180" height="60" rx="4" class="node node-distance"/>
        <text x="650" y="505" class="node-title">Inside 100&ndash;125 Yards</text>
        <text x="650" y="523" class="node-sub">timber, thick cover</text>

        <!-- Cartridge outcome nodes -->
        <rect x="810" y="70" width="150" height="50" rx="4" class="node node-outcome"/>
        <text x="885" y="100" class="node-title node-title--outcome">.350 Legend</text>

        <rect x="810" y="190" width="150" height="50" rx="4" class="node node-outcome"/>
        <text x="885" y="220" class="node-title node-title--outcome">.400 Legend</text>

        <rect x="810" y="270" width="150" height="50" rx="4" class="node node-outcome"/>
        <text x="885" y="300" class="node-title node-title--outcome">.360 Buckhammer</text>

        <rect x="810" y="390" width="150" height="50" rx="4" class="node node-outcome"/>
        <text x="885" y="420" class="node-title node-title--outcome">.45-70 Gov't</text>

        <rect x="810" y="480" width="150" height="50" rx="4" class="node node-outcome"/>
        <text x="885" y="510" class="node-title node-title--outcome">.450 Bushmaster</text>

        <!-- Connecting lines: recoil -> platform -->
        <path class="link" d="M220,100 C265,100 265,100 310,100"/>
        <path class="link" d="M220,300 C265,300 265,230 310,230"/>
        <path class="link" d="M220,300 C265,300 265,370 310,370"/>
        <path class="link" d="M220,510 C265,510 265,510 310,510"/>
        <path class="link" d="M220,510 C265,510 265,590 310,590"/>

        <!-- Connecting lines: platform -> distance -->
        <path class="link" d="M490,100 C525,100 525,100 560,100"/>
        <path class="link" d="M490,230 C525,230 525,300 560,300"/>
        <path class="link" d="M490,370 C525,370 525,300 560,300"/>
        <path class="link" d="M490,510 C525,510 525,510 560,510"/>
        <path class="link" d="M490,590 C525,590 525,510 560,510"/>

        <!-- Connecting lines: distance -> cartridge -->
        <path class="link" d="M740,100 C775,100 775,95 810,95"/>
        <path class="link" d="M740,300 C775,300 775,215 810,215"/>
        <path class="link" d="M740,300 C775,300 775,295 810,295"/>
        <path class="link" d="M740,300 C775,300 775,415 810,415"/>
        <path class="link" d="M740,510 C775,510 775,505 810,505"/>

      </svg>
    </div>

    <p class="footer-note"><span class="dot">&#9679;</span> This is a starting framework, not a rulebook &mdash; always confirm your state's legal caliber and case-length window before buying (see the <a href="/zone-map/">Zone Map</a>) and pattern any rifle with your actual hunting load before the season opens.</p>
  </div>
</div>

<style>
  .decision-tree {
    --bg: #1B211C;
    --panel: #232B24;
    --line: #3C463D;
    --orange: #FF6A1A;
    --gold: #C9A25E;
    --text: #EFEAE0;
    --text-dim: #A8B0A2;

    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', -apple-system, sans-serif;
    padding: 36px 24px 44px;
    border-radius: 6px;
    margin: 2rem 0;
  }
  .decision-tree .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; letter-spacing: .14em; text-transform: uppercase;
    color: var(--orange); margin: 0 0 10px;
  }
  .decision-tree h2 {
    font-family: 'Oswald', sans-serif; font-weight: 700;
    font-size: clamp(24px, 4vw, 34px); letter-spacing: .01em;
    margin: 0 0 10px; color: var(--text); text-transform: uppercase;
  }
  .decision-tree .sub { color: var(--text-dim); font-size: 15px; max-width: 640px; line-height: 1.55; margin: 0 0 24px; }

  .decision-tree .tree-card {
    background: var(--panel); border: 1px solid var(--line); border-radius: 4px;
    padding: 18px; position: relative; overflow-x: auto;
  }
  .decision-tree .tree-card::before {
    content: ""; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--orange), transparent 60%);
  }
  .decision-tree svg { width: 100%; height: auto; display: block; min-width: 640px; }

  .decision-tree .col-label {
    font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: .1em;
    fill: var(--text-dim); text-transform: uppercase;
  }

  .decision-tree .node { stroke: var(--line); stroke-width: 1.5; }
  .decision-tree .node-recoil { fill: rgba(110,134,199,.16); stroke: #6E86C7; }
  .decision-tree .node-platform { fill: rgba(201,162,94,.16); stroke: var(--gold); }
  .decision-tree .node-distance { fill: rgba(79,122,91,.2); stroke: #4F7A5B; }
  .decision-tree .node-outcome { fill: rgba(255,106,26,.14); stroke: var(--orange); }

  .decision-tree .node-title {
    font-family: 'Oswald', sans-serif; font-weight: 600; font-size: 14px;
    fill: var(--text); text-anchor: middle;
  }
  .decision-tree .node-title--outcome { font-size: 15px; fill: var(--orange); }
  .decision-tree .node-sub {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    fill: var(--text-dim); text-anchor: middle;
  }

  .decision-tree .link { fill: none; stroke: var(--line); stroke-width: 1.5; }

  .decision-tree .footer-note { margin-top: 20px; font-size: 12px; color: var(--text-dim); display: flex; gap: 8px; align-items: flex-start; line-height: 1.5; }
  .decision-tree .footer-note .dot { color: var(--orange); flex: none; }
  .decision-tree .footer-note a { color: var(--gold); }
</style>
