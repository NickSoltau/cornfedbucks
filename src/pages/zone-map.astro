---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Straight-Wall Cartridge Zone Map" description="Tap a state to see current straight-wall cartridge and rifle rules for deer season in Ohio, Michigan, Indiana, and Iowa.">
  <section class="zone-map-section">
    <div class="zone-map">
    <div class="wrap">
  <p class="eyebrow">CornfedBucks &middot; Regulation Reference</p>
  <h1>Straight-Wall Cartridge Zones</h1>
  <p class="sub">Tap a state to see current firearm rules for deer season. Rules vary by state — some restrict by geography, some by calendar week. Always confirm with your state DNR before you hunt.</p>

  <div class="layout">
    <div class="map-card">
      <svg viewBox="0 0 640 520" xmlns="http://www.w3.org/2000/svg">

        <!-- IOWA -->
        <polygon id="iowa" class="state" data-state="iowa" fill="#6E86C7"
          points="40,190 260,175 275,300 250,410 90,420 45,320"/>
        <text x="130" y="300" class="state-label">Iowa</text>
        <text x="105" y="318" class="zone-sub">statewide / by season</text>

        <!-- MICHIGAN UPPER PENINSULA -->
        <polygon id="mi-up" class="state" data-state="michigan-north" fill="#4F7A5B"
          points="330,40 480,55 500,95 460,120 360,110 320,80"/>
        <!-- MICHIGAN NORTHERN LOWER PENINSULA -->
        <polygon id="mi-north" class="state" data-state="michigan-north" fill="#4F7A5B"
          points="400,130 540,120 555,220 520,235 415,230 395,180"/>
        <!-- MICHIGAN SOUTHERN LOWER PENINSULA (Limited Firearm Zone) -->
        <polygon id="mi-south" class="state" data-state="michigan-south" fill="#C9A25E"
          points="415,235 520,238 545,320 470,345 400,320 390,270"/>
        <line class="zone-divider" x1="392" y1="232" x2="540" y2="236"/>
        <text x="435" y="180" class="state-label">Michigan</text>
        <text x="415" y="196" class="zone-sub">north: any centerfire</text>
        <text x="425" y="295" class="state-label" fill="#12160F">L.F.Z.</text>
        <text x="405" y="311" class="zone-sub">straight-wall only</text>

        <!-- INDIANA -->
        <polygon id="indiana" class="state" data-state="indiana" fill="#4F7A5B"
          points="395,330 468,330 475,470 400,478 388,400"/>
        <text x="398" y="400" class="state-label">Indiana</text>
        <text x="392" y="416" class="zone-sub">statewide</text>

        <!-- OHIO -->
        <polygon id="ohio" class="state" data-state="ohio" fill="#4F7A5B"
          points="480,330 590,320 605,400 570,460 500,470 480,400"/>
        <text x="510" y="390" class="state-label">Ohio</text>
        <text x="500" y="406" class="zone-sub">statewide</text>

      </svg>

      <div class="legend">
        <span><i class="swatch" style="background:#4F7A5B"></i>Statewide straight-wall / rifle rule</span>
        <span><i class="swatch" style="background:#C9A25E"></i>Zoned (differs by region)</span>
        <span><i class="swatch" style="background:#6E86C7"></i>Restricted by season, not geography</span>
      </div>
    </div>

    <div class="panel" id="panel">
      <p class="placeholder">Tap <b>Ohio</b>, <b>Michigan</b>, <b>Indiana</b>, or <b>Iowa</b> on the map to see legal calibers, case-length limits, and where the rule applies.</p>
    </div>
  </div>

  <p class="footer-note"><span class="dot">&#9679;</span> Regulations shown reflect rules as of the 2026 season and are summarized for content-planning purposes — they are not a legal reference. Michigan's Limited Firearm Zone rules are under legislative review for 2026; Indiana expanded past straight-wall-only in 2025. Verify current-year rules with each state's DNR before hunting.</p>
</div>
  </div>
  </section>
</Layout>

<style>
  .zone-map-section { padding: 3rem 0 5rem; }
.zone-map {
  --bg: #1B211C;
  --panel: #232B24;
  --line: #3C463D;
  --orange: #FF6A1A;
  --gold: #C9A25E;
  --text: #EFEAE0;
  --text-dim: #A8B0A2;
  --statewide: #4F7A5B;
  --zoned: #C9A25E;
  --season: #6E86C7;

  background: var(--bg);
  color: var(--text);
  font-family: 'Inter', sans-serif;
  padding: 36px 24px 60px;
  border-radius: 6px;
}
.zone-map .eyebrow {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px; letter-spacing: .14em; text-transform: uppercase;
  color: var(--orange); margin: 0 0 10px;
}
.zone-map h1 {
  font-family: 'Oswald', sans-serif; font-weight: 700;
  font-size: clamp(28px, 4vw, 42px); letter-spacing: .01em;
  margin: 0 0 10px; color: var(--text); text-transform: uppercase;
}
.zone-map .sub { color: var(--text-dim); font-size: 15px; max-width: 640px; line-height: 1.55; margin: 0 0 28px; }
.zone-map .layout { display: grid; grid-template-columns: 1.35fr 1fr; gap: 28px; align-items: start; }
@media (max-width: 860px) { .zone-map .layout { grid-template-columns: 1fr; } }
.zone-map .map-card {
  background: var(--panel); border: 1px solid var(--line); border-radius: 4px;
  padding: 20px; position: relative;
}
.zone-map .map-card::before {
  content: ""; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, var(--orange), transparent 60%);
}
.zone-map svg { width: 100%; height: auto; display: block; }
.zone-map .state { stroke: var(--bg); stroke-width: 2.5; cursor: pointer; transition: filter .15s ease; }
.zone-map .state:hover { filter: brightness(1.18); }
.zone-map .state.active { filter: brightness(1.3); }
.zone-map .state-label {
  font-family: 'Oswald', sans-serif; font-size: 15px; font-weight: 600;
  fill: #12160F; pointer-events: none; letter-spacing: .03em; text-transform: uppercase;
}
.zone-map .zone-sub { font-family: 'JetBrains Mono', monospace; font-size: 9.5px; fill: #12160F; pointer-events: none; opacity: .75; }
.zone-map .zone-divider { stroke: var(--bg); stroke-width: 2; stroke-dasharray: 5 4; }
.zone-map .legend { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 18px; font-size: 12.5px; color: var(--text-dim); }
.zone-map .legend span { display: inline-flex; align-items: center; gap: 7px; }
.zone-map .swatch { width: 11px; height: 11px; border-radius: 2px; display: inline-block; }
.zone-map .panel {
  background: var(--panel); border: 1px solid var(--line); border-radius: 4px;
  padding: 26px; min-height: 380px; display: flex; flex-direction: column;
}
.zone-map .panel-tag {
  font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: .1em;
  text-transform: uppercase; padding: 4px 9px; border-radius: 2px;
  display: inline-block; margin-bottom: 14px; width: fit-content;
}
.zone-map .tag-statewide { background: rgba(79,122,91,.22); color: #8FCF9F; }
.zone-map .tag-zoned { background: rgba(201,162,94,.22); color: var(--gold); }
.zone-map .tag-season { background: rgba(110,134,199,.22); color: #9FB2E8; }
.zone-map .panel h2 { font-family: 'Oswald', sans-serif; font-size: 24px; text-transform: uppercase; margin: 0 0 4px; color: var(--text); }
.zone-map .panel .zone-name { color: var(--text-dim); font-size: 13px; margin: 0 0 18px; }
.zone-map .spec-row { display: flex; justify-content: space-between; gap: 12px; padding: 10px 0; border-top: 1px solid var(--line); font-size: 13.5px; }
.zone-map .spec-row:first-of-type { border-top: none; }
.zone-map .spec-label { color: var(--text-dim); }
.zone-map .spec-val { font-family: 'JetBrains Mono', monospace; font-size: 12.5px; text-align: right; color: var(--text); }
.zone-map .panel-note { margin-top: auto; padding-top: 16px; font-size: 12.5px; line-height: 1.5; color: var(--text-dim); border-top: 1px solid var(--line); }
.zone-map .panel-note strong { color: var(--orange); }
.zone-map .placeholder { color: var(--text-dim); font-size: 14px; line-height: 1.6; margin: auto 0; }
.zone-map .placeholder b { color: var(--text); }
.zone-map .footer-note { margin-top: 22px; font-size: 12px; color: var(--text-dim); display: flex; gap: 8px; align-items: flex-start; line-height: 1.5; }
.zone-map .footer-note .dot { color: var(--orange); flex: none; }

</style>

<script is:inline>

const data = {
  ohio: {
    tag: "Statewide", tagClass: "tag-statewide",
    name: "Ohio", zone: "One rule applies everywhere in the state",
    specs: [
      ["Legal rifle calibers", ".357 to .50 caliber, straight-wall only"],
      ["Bottleneck rifles", "Not legal for deer, any season"],
      ["Also legal", "Shotguns (slugs), muzzleloaders, handguns \u2265.357"],
      ["Magazine limit", "3 rounds total, chamber + magazine"],
      ["Popular calibers", ".350 Legend, .450 Bushmaster, .44 Mag, .45-70"]
    ],
    note: "Ohio's rule is the simplest in the region \u2014 no geographic zones, one caliber window statewide."
  },
  "michigan-north": {
    tag: "Zoned \u2014 Northern Zone", tagClass: "tag-zoned",
    name: "Michigan", zone: "Upper Peninsula + northern Lower Peninsula",
    specs: [
      ["Legal rifles", "Any centerfire rifle, including bottleneck cartridges"],
      ["Restriction type", "None \u2014 traditional open rifle country"],
      ["Applies to", "U.P. and the northern half of the Lower Peninsula"]
    ],
    note: "This is the \u201ceasy\u201d half of Michigan \u2014 the straight-wall rule only kicks in once you cross into the southern Lower Peninsula."
  },
  "michigan-south": {
    tag: "Zoned \u2014 Limited Firearm Zone", tagClass: "tag-zoned",
    name: "Michigan", zone: "Southern Lower Peninsula (\u201cZone 3\u201d)",
    specs: [
      ["Legal rifle calibers", ".35 caliber or larger, straight-wall only"],
      ["Case length window", "1.16\u2033 minimum \u2013 1.80\u2033 maximum"],
      ["Bottleneck rifles", "Not legal in this zone"],
      ["Popular calibers", ".350 Legend, .450 Bushmaster, .44 Mag"]
    ],
    note: "Watch this one \u2014 Michigan revised its geographic rifle line for 2026, but the Limited Firearm Zone cartridge rules still apply within it. Confirm current wording in the Michigan Deer Digest before publishing specifics."
  },
  indiana: {
    tag: "Statewide", tagClass: "tag-statewide",
    name: "Indiana", zone: "One rule applies everywhere in the state",
    specs: [
      ["Legal rifles", "Any centerfire rifle, 5.56mm (.223\u2033) bullet diameter or larger"],
      ["Straight-wall requirement", "Removed \u2014 no longer required"],
      ["Full metal jacket", "Not legal for deer"],
      ["Ammo carry limit", "10 rounds while hunting deer"]
    ],
    note: "Heads up: Indiana expanded past straight-wall-only in 2025. It now allows most centerfire rifles, so it no longer fits the \u201cSWC-restricted\u201d framing the way Ohio, Michigan, and Iowa do."
  },
  iowa: {
    tag: "Statewide, season-limited", tagClass: "tag-season",
    name: "Iowa", zone: "Same rule everywhere \u2014 restricted by calendar, not location",
    specs: [
      ["Legal bullet diameter", ".350\u2033 to .500\u2033, straight-wall or necked-down"],
      ["Minimum muzzle energy", "500 ft-lbs"],
      ["When it's legal", "Youth/disabled season + 1st & 2nd shotgun seasons only"],
      ["Not legal during", "Archery-only or muzzleloader-only seasons"],
      ["Popular calibers", ".350 Legend, .450 Bushmaster, .45-70, .44 Mag"]
    ],
    note: "Iowa's twist: the caliber window is identical statewide, but it's only legal during specific season windows \u2014 useful nuance for a scheduling-focused CTA."
  }
};

document.querySelectorAll('.state').forEach(el => {
  el.addEventListener('click', () => {
    document.querySelectorAll('.state').forEach(s => s.classList.remove('active'));
    document.querySelectorAll('[data-state="'+el.dataset.state+'"]').forEach(s => s.classList.add('active'));
    const d = data[el.dataset.state];
    document.getElementById('panel').innerHTML = `
      <span class="panel-tag ${d.tagClass}">${d.tag}</span>
      <h2>${d.name}</h2>
      <p class="zone-name">${d.zone}</p>
      ${d.specs.map(s => `<div class="spec-row"><span class="spec-label">${s[0]}</span><span class="spec-val">${s[1]}</span></div>`).join('')}
      <p class="panel-note">${d.note}</p>
    `;
  });
});

</script>
