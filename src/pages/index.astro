---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { getCollection } from 'astro:content';

const fieldNoteNum = (fn: string) => parseInt(fn.replace(/\D/g, ''), 10) || 0;

const posts = (await getCollection('blog'))
  .sort((a, b) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf() ||
    fieldNoteNum(b.data.fieldNote) - fieldNoteNum(a.data.fieldNote)
  )
  .slice(0, 3);

const latest = posts[0];
---
<Layout title="Home">
  <section class="hero" role="img" aria-label="Whitetail buck standing at the edge of a cut cornfield at dusk">
    <div class="wrap hero__inner">
      <a href={`/blog/${latest.id}`} class="eyebrow eyebrow--link">{latest.data.fieldNote} — Just Published</a>
      <h1>Corn-fed bucks live<br />on the edge of the field, <br />not in the middle of the woods.</h1>
      <p class="hero__sub">
        Field reports and ground-level strategy for hunters working real Midwest row-crop
        ground — fence lines, drainage ditches, and the three days after the combine comes through.
      </p>
      <p class="hero__authority">Regulations checked, not recycled — we track every rule change so you don't have to.</p>
      <div class="hero__actions">
        <a href="/blog" class="btn btn-primary">Read the Latest Report</a>
        <a href="#newsletter" class="btn btn-secondary">Get the Newsletter</a>
      </div>
    </div>
    <p class="hero__credit">AI-generated illustration.</p>
  </section>

  <div class="corn-row-divider" aria-hidden="true"></div>

  <section class="featured">
    <div class="wrap">
      <p class="eyebrow">Recent field notes</p>
      <h2>From the log</h2>
      <div class="featured__grid">
        {posts.map((post) => (
          <ArticleCard
            slug={post.id}
            title={post.data.title}
            description={post.data.description}
            fieldNote={post.data.fieldNote}
            pubDate={post.data.pubDate}
          />
        ))}
      </div>
      <a href="/blog" class="featured__more">All field notes &rarr;</a>
    </div>
  </section>

  <NewsletterSignup />
</Layout>

<style>
  .hero {
    position: relative;
    background-color: var(--dusk);
    background-image:
      linear-gradient(100deg, rgba(34, 27, 20, 0.82) 0%, rgba(34, 27, 20, 0.55) 55%, rgba(34, 27, 20, 0.35) 100%),
      url('/images/cornfield-buck.jpg');
    background-image:
      linear-gradient(100deg, rgba(34, 27, 20, 0.82) 0%, rgba(34, 27, 20, 0.55) 55%, rgba(34, 27, 20, 0.35) 100%),
      image-set(url('/images/cornfield-buck.webp') type('image/webp'), url('/images/cornfield-buck.jpg') type('image/jpeg'));
    background-size: cover;
    background-position: center 40%;
    padding: 5rem 0 4rem;
  }
  .hero .eyebrow--link {
    display: inline-block;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s ease;
  }
  .hero .eyebrow--link:hover {
    border-bottom-color: var(--blaze);
  }
  .hero__inner { max-width: 700px; }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.1rem);
    margin: 0.6rem 0 1.25rem;
    color: var(--frost);
  }
  .hero__sub {
    font-size: 1.05rem;
    max-width: 540px;
    margin: 0 0 1.1rem;
    color: var(--frost);
    opacity: 0.92;
  }
  .hero__authority {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--frost);
    background: rgba(20, 16, 11, 0.55);
    border-left: 3px solid var(--blaze);
    padding: 0.5rem 0.75rem;
    margin: 0 0 1.9rem;
    max-width: 540px;
    line-height: 1.5;
  }
  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .hero .btn-secondary {
    border-color: var(--frost);
    color: var(--frost);
  }
  .hero .btn-secondary:hover {
    background: var(--frost);
    color: var(--ink);
  }
  .hero__credit {
    position: absolute;
    right: 1rem;
    bottom: 0.6rem;
    margin: 0;
    font-family: var(--font-tag);
    font-size: 0.65rem;
    letter-spacing: 0.03em;
    color: var(--frost);
    opacity: 0.65;
  }

  .featured {
    padding: 4rem 0;
  }
  .featured h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin: 0.4rem 0 2rem;
  }
  .featured__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .featured__more {
    display: inline-block;
    margin-top: 2rem;
    font-family: var(--font-tag);
    font-size: 0.85rem;
    text-decoration: none;
    color: var(--blaze);
  }
</style>
