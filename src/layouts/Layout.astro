---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Field reports and ground-level whitetail strategy for Midwest row-crop hunters." } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Cornfed Bucks</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<script type="text/javascript" src="http://classic.avantlink.com/affiliate_app_confirm.php?mode=js&authResponse=49779105b35b0355e1b274c5ee8cbfcdf290ed66"></script>
  </head>
  <body>
    <header class="site-header">
      <div class="wrap site-header__inner">
        <a href="/" class="site-header__brand">Cornfed<span>Bucks</span></a>
        <nav class="site-header__nav">
          <a href="/blog">Field Notes</a>
          <a href="/about">About</a>
          <a href="/#newsletter">Newsletter</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <div class="corn-row-divider" aria-hidden="true"></div>

    <footer class="site-footer">
      <div class="wrap site-footer__inner">
        <p class="site-footer__brand">Cornfed Bucks</p>
        <p class="site-footer__tag">Ground-level whitetail strategy for row-crop country.</p>
        <p class="site-footer__copy">&copy; {new Date().getFullYear()} Cornfed Bucks. Bryan, Ohio.</p>
        <p class="site-footer__disclosure">Some links on this site are affiliate links, including Amazon Associate links. As an Amazon Associate, we earn from qualifying purchases. <a href="/affiliate-disclosure">Learn more</a>.</p>
      </div>
    </footer>
    <script type="text/javascript" async src="https://subscribe-forms.beehiiv.com/attribution.js"></script>
    <style>
      .site-header {
        background: var(--dusk);
        color: var(--frost);
      }
      .site-header__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 1.1rem;
        padding-bottom: 1.1rem;
      }
      .site-header__brand {
        font-family: var(--font-display);
        font-weight: 600;
        font-size: 1.25rem;
        text-decoration: none;
        color: var(--frost);
      }
      .site-header__brand span { color: var(--husk); }
      .site-header__nav {
        display: flex;
        gap: 1.5rem;
        font-family: var(--font-tag);
        font-size: 0.82rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .site-header__nav a {
        text-decoration: none;
        color: var(--frost);
        opacity: 0.85;
      }
      .site-header__nav a:hover { opacity: 1; color: var(--husk); }

      .site-footer {
        background: var(--ink);
        color: var(--frost);
        padding: 2.5rem 0 3rem;
      }
      .site-footer__inner { text-align: center; }
      .site-footer__brand {
        font-family: var(--font-display);
        font-size: 1.1rem;
        margin: 0;
      }
      .site-footer__tag {
        font-family: var(--font-tag);
        font-size: 0.78rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--husk);
        margin: 0.4rem 0 1.2rem;
      }
      .site-footer__copy {
        font-size: 0.82rem;
        opacity: 0.6;
        margin: 0;
      }
      .site-footer__disclosure {
        font-size: 0.74rem;
        opacity: 0.5;
        max-width: 520px;
        margin: 0.75rem auto 0;
        line-height: 1.5;
      }
      .site-footer__disclosure a {
        color: inherit;
        text-decoration: underline;
      }

      @media (max-width: 560px) {
        .site-header__inner { flex-direction: column; gap: 0.75rem; }
        .site-header__nav { gap: 1rem; }
      }
    </style>
  </body>
</html>
